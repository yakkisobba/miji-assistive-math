<?xml version="1.0" encoding="utf-8"?>
<!--
    Single module row used in the Home screen Self-Learning Modules list.
    Bind in HomeActivity:
        val view = findViewById<View>(R.id.moduleAddition)
        view.findViewById<ImageView>(R.id.ivModuleIcon).setImageResource(R.drawable.ic_plus)
        view.findViewById<TextView>(R.id.tvModuleName).text = getString(R.string.module_addition)
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/bg_card_surface"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="14dp"
    android:clickable="true"
    android:focusable="true">

    <!-- Icon box  -->
    <FrameLayout
        android:layout_width="36dp"
        android:layout_height="36dp"

        android:layout_marginEnd="14dp">

        <ImageView
            android:id="@+id/ivModuleIcon"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_plus"
            android:contentDescription="Module icon"
            android:scaleType="fitCenter"
            app:tint="#EBFF57" />
        <!--
            REPLACE: android:src="@drawable/ic_placeholder_operator"
            WITH   : android:src="@drawable/ic_plus"  (or ic_minus, ic_multiply, ic_divide, ic_mixed)
            Icons should be black (#0D0D0D) 20×20dp SVG/PNG
        -->
    </FrameLayout>

    <!-- Module name -->
    <TextView
        android:id="@+id/tvModuleName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="Module"
        android:textSize="14sp"
        android:fontFamily="@font/inter_medium"
        android:textColor="@color/accent" />

    <!-- Chevron right -->
    <ImageView
        android:id="@+id/ivChevron"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:src="@drawable/ic_chevron_right"
        android:contentDescription="Open module"
        android:scaleType="fitCenter"
        android:alpha="0.7" />

</LinearLayout>